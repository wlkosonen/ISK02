# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ANTHROPIC_API_KEY: Required for Anthropic (Claude) API calls.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# OLLAMA_BASE_URL: Enables SERVER-SIDE Ollama and points the server at an instance.
# The SERVER makes the call, so "localhost" here = the server's machine. LEAVE
# EMPTY/UNSET on any public or shared deploy, or every visitor can use the host's
# Ollama (and hardware). Set it ONLY when you self-host this app with Ollama on the
# same box (e.g. http://host.docker.internal:11434 under Docker; run Ollama with
# OLLAMA_HOST=0.0.0.0). Visitors who want their OWN local models don't need this —
# they enable Settings -> Ollama -> "Use my own machine", which connects their
# browser straight to their localhost Ollama.
# OLLAMA_BASE_URL="http://host.docker.internal:11434"

# OLLAMA_ALLOW_ANY: Set "true" ONLY on a trusted self-host to allow a non-local /
# non-private Ollama URL (disables the SSRF guard). Never set this on a public deploy.
# OLLAMA_ALLOW_ANY="false"

# OPENROUTER_API_KEY: Optional. A single OpenRouter key (free at openrouter.ai/keys)
# unlocks GPT, Claude, Gemini, Grok and Llama through one provider. Models whose
# id ends in ":free" cost nothing (rate-limited). Can also be entered in the UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

